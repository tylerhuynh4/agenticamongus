# Path to llama.cpp executable (recommended on Windows: C:/tools/llama.cpp/build/bin/Release/llama-completion.exe)
LLAMA_CPP_BIN=

# Path to GGUF model file (example: C:/models/mistral-7b-instruct-q4_k_m.gguf)
LLAMA_MODEL_PATH=

# Optional settings
LLAMA_CONTEXT_SIZE=2048
LLAMA_TEMPERATURE=0.2
LLAMA_MAX_TOKENS=16
LLAMA_TIMEOUT_MS=120000
